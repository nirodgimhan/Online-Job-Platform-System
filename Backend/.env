# Server Configuration
PORT=5000
NODE_ENV=development

# Database
MONGO_URI=mongodb://localhost:27017/jobportal

# JWT Secret (change to a strong random string in production)
JWT_SECRET=your-super-secret-jwt-key-change-this

# CORS Allowed Origins (comma separated, no spaces)
CLIENT_URLS=http://localhost:3000,http://localhost:3001,http://localhost:4200

# Optional: Email configuration (if you add email sending later)
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USER=your-email@gmail.com
# EMAIL_PASS=your-app-password